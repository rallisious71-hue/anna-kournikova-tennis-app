# Copy this file to ".env" and fill in the values before running the app.
# Without DATABASE_URL, the login/register screens will always fail with
# "Database not available", because the server can never connect to a DB.

# MySQL connection string used by drizzle-orm (server/db.ts, drizzle.config.ts)
DATABASE_URL=

# Used to sign session cookies (server/_core/env.ts)
JWT_SECRET=change-me

# Port the API server listens on (defaults to 3000 if not set)
PORT=3000

# --- After setting DATABASE_URL, run these once ---
#   pnpm db:push          # create the tables
#   pnpm seed:players      # create the 4 players + admin account
#
# Default seeded accounts (password is always equal to the username):
#   stefanos / stefanos
#   andreas  / andreas
#   notis    / notis
#   manos    / manos
#   admin    / admin
